# auak agenty Secrets Configuration
# Copy this file to secrets.properties and fill in your own values.
# DO NOT commit secrets.properties to version control!

# Doubao AI - Get your API key from https://www.volcengine.com/product/doubao
DOUBAO_API_KEY=your_api_key_here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL_ID=your_model_id_here

# agenty Platform
agenty_APP_ID=your_app_id_here
agenty_APP_SECRET=your_app_secret_here

# Doubao Realtime Speech API
DOUBAO_SPEECH_APP_ID=your_speech_app_id_here
DOUBAO_SPEECH_ACCESS_KEY=your_speech_access_key_here

# Picovoice Porcupine - Wake word detection
PICOVOICE_ACCESS_KEY=your_picovoice_access_key_here
